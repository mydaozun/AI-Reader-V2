    ],
    "_note": "福道/法道在西游记中是国名时例外，需上下文判断"
  },
  "descriptive_phrases": {
    "_desc": "描述性短语非地名 (A-描述性短语)",
    "suffixes": ["处", "之处", "所在", "所在处", "之地", "地方"],
    "patterns": [
      "^(三藏|唐僧|悟空|行者|八戒|沙僧|师父).*处$",
      ".*(被擒|被困|修炼|住|坐|立|歇).*处$",
      "^安歇.*",
      "^借宿.*"
    ]
  },
  "single_char_generic": {
    "_desc": "单字通名（无专名前缀）(A-单字通名)",
    "exact": [
      "山", "洞", "殿", "宫", "府", "城", "寺", "观", "庙", "庵",
      "涧", "河", "江", "湖", "海", "潭", "池", "泉", "溪",
