  "non_location_entities": {
    "_desc": "人物名/物品名/动物名 (A-非地名)",
    "exact": [
      "孙大圣", "齐天大圣", "行者", "孙行者", "猴王", "美猴王",
      "唐僧", "三藏", "玄奘", "圣僧", "唐三藏",
