  "buddhist_concepts": {
    "_desc": "佛道概念非地名 (A-概念非地名)",
    "exact": [
      "人道", "仙道", "贵道", "神道", "鬼道", "畜生道", "饿鬼道", "地狱道", "天道", "修罗道",
